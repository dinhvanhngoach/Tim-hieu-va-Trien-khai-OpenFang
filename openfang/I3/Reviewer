# Tool: tóm tắt text thành 1 câu
def tool_summarize(text):
    # lấy câu đầu tiên làm tóm tắt đơn giản
    summary = text.split(".")[0]
    return summary

# Agent Reviewer
class Reviewer:
    def __init__(self):
        self.name = "Reviewer"
        self.description = "Receive a text and give a short evaluation or summary."

    def run(self, text):
        print("\n[Reviewer dang phan tich ket qua...]")

        summary = tool_summarize(str(text))

        print("Summary:", summary)

        return summary
